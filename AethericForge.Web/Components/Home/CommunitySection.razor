<section class="community-section">
    <SectionHeader Model="Model.Header" />

    <div class="community-section__grid">
        @foreach (var audience in Model.Audiences)
        {
            <article class="community-card">
                <h3 class="community-card__title">
                    @audience.Title
                </h3>

                <p class="community-card__description">
                    @audience.Description
                </p>

                <a class="community-card__link" href="@audience.Url">
                    Get Involved →
                </a>
            </article>
        }
    </div>
</section>

@code
{
    [Parameter, EditorRequired]
    public required CommunitySectionModel Model { get; init; }
}